# Public domain whose DNS A/AAAA record points at this host.
# Caddy obtains an HTTPS certificate for it automatically.
DOMAIN=notes.example.com

# Email for Let's Encrypt certificate notices (optional but recommended).
ACME_EMAIL=you@example.com

# Secret used to sign auth tokens. Generate one with: openssl rand -hex 32
JWT_SECRET=

# Optional: auto-create this admin account on first startup (only if no users exist).
# You can instead create users any time with:
#   docker compose exec server luminotes-server user add <name>
ADMIN_USER=
ADMIN_PASSWORD=
